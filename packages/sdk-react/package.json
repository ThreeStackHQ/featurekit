{
  "name": "@featurekit/sdk-react",
  "version": "0.1.0",
  "description": "FeatureKit React SDK — hooks and components for feature flags",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && tsc -p tsconfig.declarations.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "@featurekit/sdk": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "feature-flags",
    "react",
    "a/b-testing",
    "featurekit"
  ],
  "license": "MIT"
}
